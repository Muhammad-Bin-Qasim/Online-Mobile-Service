@model OnlineMobileServices.Models.Feedback

@{
    ViewData["Title"] = "Feedback";
}

<style>

    .feedback-section {
        padding: 60px 0;
        background: #f4f6f9;
        min-height: 70vh;
    }

    .feedback-card {
        max-width: 650px;
        margin: auto;
        background: #ffffff;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .feedback-title {
        text-align: center;
        margin-bottom: 25px;
    }

        .feedback-title h2 {
            font-weight: 700;
        }

    .submit-btn {
        width: 100%;
        font-weight: 600;
        padding: 10px;
    }

</style>

<div class="container feedback-section">

    <!-- PAGE TITLE -->
    <div class="feedback-title">
        <h2>Feedback</h2>
        <p class="text-muted">
            We value your opinion. Help us improve our services.
        </p>
    </div>

    <!-- SUCCESS ALERT -->
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            alert("@TempData["SuccessMessage"]");
            window.location.href = '@Url.Action("Index", "Home")';
        </script>
    }

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success text-center">
            @ViewBag.Success
        </div>
    }

    <!-- CARD -->
    <div class="feedback-card">

        <h5 class="mb-3 fw-semibold">Share your experience</h5>
        <p class="text-muted small mb-4">
            Let us know what you think about our mobile recharge service.
        </p>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <!-- NAME -->
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Your Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- MESSAGE -->
            <div class="mb-3">
                <label class="form-label">Your Feedback</label>
                <textarea asp-for="Message"
                          class="form-control"
                          rows="5"
                          placeholder="Tell us what you liked or how we can improve..."></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <!-- SUBMIT -->
            <button type="submit" class="btn btn-primary submit-btn">
                Submit Feedback
            </button>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}