@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Online Mobile Services</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" />

    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
</head>
<style>

    html, body {
        font-family: 'Poppins', sans-serif !important;
        overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 {
        font-weight: 600;
    }

    /* Container spacing for mobile */
    .container, .container-fluid {
        padding-left: 15px;
        padding-right: 15px;
    }

    /* Make tables scrollable on mobile */
    .table-responsive {
        overflow-x: auto;
    }

    /* Cards spacing */
    .card {
        margin-bottom: 20px;
    }

    /* Hero sections responsive */
    @@media (max-width: 768px) {
        .admin-hero, .history-hero, .users-hero, .account-hero, .about-hero

    {
        padding: 25px;
        text-align: center;
    }

    h1 {
        font-size: 26px;
    }

    h2 {
        font-size: 22px;
    }

    h3 {
        font-size: 20px;
    }

    .stat-card {
        padding: 20px;
    }

    .auth-card {
        padding: 25px;
    }

    .history-container,
    .users-container,
    .account-container {
        margin: 30px 15px;
    }

    }

    /* Buttons full width on small screens */
    @@media (max-width: 576px) {
        .btn

    {
        width: 100%;
        margin-bottom: 10px;
    }

    }

    @@media (max-width: 576px) {
        .form-floating > label

    {
        font-size: 14px;
    }

    .form-control {
        font-size: 14px;
    }

    }
</style>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">
                ONLINE MOBILE SERVICES
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>


            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto">

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <!-- GUEST MODE -->

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Recharge" ? "active" : "")"
                               asp-controller="Recharge"
                               asp-action="Index">
                                Online Recharge
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(currentController == "Support" || currentController == "Feedback" ? "active" : "")"
                               data-bs-toggle="dropdown"
                               href="#">
                                Support
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="Feedback">
                                        Feedback
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="Contact">
                                        Contact Us
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="CustomerCare">
                                        Customer Care
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="SiteMap">
                                        Site Map
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "About" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="About">
                                About Us
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               data-bs-toggle="dropdown"
                               href="#">
                                My Account
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Identity"
                                       asp-page="/Account/Login">
                                        Login
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Identity"
                                       asp-page="/Account/Register">
                                        Register
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <!-- ADMIN MODE -->

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Admin" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="Dashboard">
                                Admin Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  method="post">
                                <button class="nav-link btn btn-link text-white">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <!-- USER MODE -->

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Recharge" ? "active" : "")"
                               asp-controller="Recharge"
                               asp-action="Index">
                                Online Recharge
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Bill" ? "active" : "")"
                               asp-controller="Bill"
                               asp-action="Index">
                                Post Bill
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Account" ? "active" : "")"
                               asp-controller="Account"
                               asp-action="Index">
                                My Account
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(currentController == "Support" || currentController == "Feedback" ? "active" : "")"
                               data-bs-toggle="dropdown"
                               href="#">
                                Support
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="Feedback">
                                        Feedback
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="Contact">
                                        Contact Us
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="CustomerCare">
                                        Customer Care
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Support"
                                       asp-action="SiteMap">
                                        Site Map
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" && currentAction == "About" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="About">
                                About Us
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  method="post">
                                <button class="nav-link btn btn-link text-white">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="footer mt-5">
        <div class="container text-center text-white">
            <h5>Online Mobile Services</h5>
            <p>Fast, Secure & Easy Mobile Recharge</p>

            <p>
                <i class="bi bi-telephone-fill me-2"></i>1800-123-4567
                &nbsp; | &nbsp;
                <i class="bi bi-envelope-fill me-2"></i>help@recharge.com
            </p>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 900 });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>