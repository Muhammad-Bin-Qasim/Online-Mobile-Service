@model OnlineMobileServices.Models.Transaction

<div class="container mt-5">
    <div class="card shadow-lg p-4">

        <!-- HEADER -->
        <div class="text-center mb-4">
            <h2 class="text-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                Payment Successful
            </h2>
            <p class="text-muted">Transaction Receipt</p>
        </div>

        <!-- RECEIPT TABLE -->
        <table class="table table-bordered align-middle">
            <tr>
                <th><i class="bi bi-hash"></i> Transaction ID</th>
                <td>@Model.TransactionId</td>
            </tr>

            <tr>
                <th><i class="bi bi-calendar-event"></i> Date</th>
                <td>@Model.Date.ToString("dd-MM-yyyy HH:mm")</td>
            </tr>

            <tr>
                <th><i class="bi bi-phone"></i> Mobile Number</th>
                <td>@Model.MobileNumber</td>
            </tr>

            <tr>
                <th><i class="bi bi-arrow-left-right"></i> Transaction Type</th>
                <td>@Model.TransactionType</td>
            </tr>

            <tr>
                <th><i class="bi bi-cash-stack"></i> Amount</th>
                <td><strong>Rs @Model.Amount</strong></td>
            </tr>

            <tr>
                <th><i class="bi bi-patch-check"></i> Status</th>
                <td>
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>
                        @Model.Status
                    </span>
                </td>
            </tr>
        </table>

        <!-- BUTTONS -->
        <div class="text-center mt-4">
            <a href="/" class="btn btn-primary me-2">
                <i class="bi bi-house-door"></i> Go Home
            </a>

            <button onclick="window.print()" class="btn btn-secondary">
                <i class="bi bi-printer"></i> Print Receipt
            </button>
        </div>

    </div>
</div>