@model List<dynamic>

@{
    ViewData["Title"] = "Manage Users";
}

<style>
    body {
        background-color: #f3f4f6;
    }

    .users-container {
        max-width: 1100px;
        margin: 60px auto;
    }

    .users-hero {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: white;
        padding: 35px;
        border-radius: 20px;
        margin-bottom: 30px;
        box-shadow: 0 15px 40px rgba(13,110,253,0.25);
    }

    .users-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    .table {
        border-radius: 15px;
        overflow: hidden;
    }

        .table thead {
            background: #0d6efd;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f1f5ff;
            transition: 0.3s;
        }

    .badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
    }

    .btn-sm {
        border-radius: 20px;
        padding: 5px 14px;
    }

</style>

<div class="users-container">

    <div class="users-hero">
        <h3><i class="bi bi-people-fill"></i> Registered Users</h3>
        <p class="mb-0">Manage roles, status and transactions</p>
    </div>

    <div class="users-card">

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Total Transactions</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@user.Email</td>

                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-primary" : "bg-secondary")">
                                    @user.Role
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-info text-dark">
                                    @user.TransactionCount
                                </span>
                            </td>

                            <td>
                                <span class="badge @(user.IsBlocked ? "bg-danger" : "bg-success")">
                                    @(user.IsBlocked ? "Blocked" : "Active")
                                </span>
                            </td>

                            <td>

                                <a asp-action="UserHistory"
                                   asp-route-userId="@user.Id"
                                   class="btn btn-sm btn-info mb-1">
                                    History
                                </a>

                                @if (!User.Identity.Name.Equals(user.Email))
                                {
                                    @if (user.IsBlocked)
                                    {
                                        <form asp-action="UnblockUser" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button class="btn btn-sm btn-warning mb-1">
                                                Unblock
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="BlockUser" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button class="btn btn-sm btn-secondary mb-1">
                                                Block
                                            </button>
                                        </form>
                                    }

                                    <form asp-action="DeleteUser"
                                          method="post"
                                          style="display:inline;"
                                          onsubmit="return confirm('Delete this user?');">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button class="btn btn-sm btn-danger mb-1">
                                            Delete
                                        </button>
                                    </form>
                                }

                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>