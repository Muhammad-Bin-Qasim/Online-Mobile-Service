@model List<OnlineMobileServices.Models.Transaction>

@{
    ViewData["Title"] = "User History";
}

<style>
    body {
        background-color: #f3f4f6;
    }

    .history-container {
        max-width: 1000px;
        margin: 60px auto;
    }

    .history-hero {
        background: linear-gradient(135deg,#0d6efd,#2563eb);
        color: white;
        padding: 35px;
        border-radius: 20px;
        margin-bottom: 30px;
        box-shadow: 0 15px 40px rgba(13,110,253,0.25);
    }

    .history-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    .table {
        border-radius: 15px;
        overflow: hidden;
    }

        .table thead {
            background: #0d6efd;
            color: white;
        }

    .badge {
        padding: 6px 12px;
        font-size: 13px;
        border-radius: 20px;
    }

    .table tbody tr:hover {
        background-color: #f1f5ff;
        transition: 0.3s;
    }

    .empty-box {
        text-align: center;
        padding: 40px;
        color: #6c757d;
    }
</style>

<div class="history-container">

    <div class="history-hero">
        <h3><i class="bi bi-clock-history"></i> Transaction History</h3>
        <p class="mb-0">All recharge & bill payment records</p>
    </div>

    <div class="history-card">

        @if (!Model.Any())
        {
            <div class="empty-box">
                <i class="bi bi-inbox" style="font-size:40px;"></i>
                <p class="mt-3">No transactions found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Mobile</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td>@t.Date.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@t.MobileNumber</td>
                                <td>
                                    <span class="badge bg-primary">
                                        @t.TransactionType
                                    </span>
                                </td>
                                <td class="fw-bold text-success">
                                    Rs @t.Amount
                                </td>
                                <td>
                                    <span class="badge @(t.Status == "Paid" ? "bg-success" : t.Status == "Pending" ? "bg-warning text-dark" : "bg-danger")">
                                        @t.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>