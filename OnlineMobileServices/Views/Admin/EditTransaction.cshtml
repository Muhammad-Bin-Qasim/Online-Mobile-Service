@model OnlineMobileServices.Models.Transaction

<style>
    .edit-card {
        max-width: 600px;
        margin: 60px auto;
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }
</style>

<div class="edit-card">
    <h4 class="mb-4 text-primary">
        <i class="bi bi-pencil-square"></i> Edit Transaction
    </h4>

    <form asp-action="EditTransaction" method="post">
        <input type="hidden" asp-for="TransactionId" />

        <div class="mb-3">
            <label class="form-label">Mobile</label>
            <input asp-for="MobileNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Amount</label>
            <input asp-for="Amount" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Type</label>
            <select asp-for="TransactionType" class="form-control">
                <option>Recharge</option>
                <option>Bill</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <select asp-for="Status" class="form-control">
                <option>Paid</option>
                <option>Pending</option>
                <option>Failed</option>
            </select>
        </div>
        @Html.AntiForgeryToken()
        <button class="btn btn-primary w-100">Save Changes</button>
    </form>
</div>